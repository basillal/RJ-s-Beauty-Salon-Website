# SMTP Configuration for Contact Form
# Copy this file to .env and fill in your values

# Your email address (sender)
SMTP_USER=your_email@gmail.com

# Your email password or App Password
# For Gmail: Use App Password (see DEPLOYMENT.md for instructions)
SMTP_PASS=your_app_password_here

# Email address where contact form submissions should be sent
RECEIVER_MAIL=recipient@example.com

# Optional: SMTP server settings (defaults shown)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# For SendGrid (alternative to Gmail):
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
